{
  "name": "little-bitta",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "cli": "bun src/cli/index.ts",
    "d": "bun --bun --env-file .env vite dev",
    "d:stripe": "stripe listen --forward-to localhost:5173/api/stripe/webhook",
    "dev": "concurrently 'bun run d' 'bun run d:stripe'",
    "b": "bun --bun vite build",
    "serve": "bun ./build/index.js",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write .",
    "clean": "rm -rf build"
  },
  "devDependencies": {
    "@eslint/compat": "^1.4.1",
    "@eslint/js": "^9.39.2",
    "@sveltejs/adapter-auto": "^7.0.0",
    "@sveltejs/adapter-node": "^5.5.2",
    "@sveltejs/kit": "^2.50.1",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@types/bun": "^1.3.7",
    "@types/node": "^24.10.9",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.14.0",
    "globals": "^16.5.0",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.4.1",
    "svelte": "^5.48.5",
    "svelte-adapter-bun": "^1.0.1",
    "svelte-check": "^4.3.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "@lucide/svelte": "^0.562.0",
    "@stripe/stripe-js": "^8.6.4",
    "bun": "^1.3.7",
    "stripe": "^20.2.0"
  }
}
